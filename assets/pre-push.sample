# --- Wingman: Codex review (non-blocking) ---
# wingman-hook-version: 2
# Runs codex review in background after push on feature branches.
# Push proceeds immediately — findings saved to .reviews/ for /review-loop.
#
# When you want a sync review on a material change, run manually pre-push:
#     codex review --base <ref>     # or --base HEAD~1 for delta
# That blocks for the review duration; fix findings; then push (this hook
# fires async behind you, which is fine — sync was already done).
#
# Configuration via environment variables (both optional):
#   WINGMAN_BASE   git base for the review diff      (default: main)
#   WINGMAN_MODEL  pin a specific codex model name   (default: codex CLI's own latest)
#
# Output JSON shape: wingman_schema_version "2" — see scripts/migrate-reviews.py
# in the wingman repo to upgrade older review files.
#
# History:
#   v2 — pass codex output via temp-file path in WINGMAN_REVIEW_INPUT instead
#        of inlining the full review (often hundreds of KB) into envp[]. On
#        macOS, argv + envp share ARG_MAX, so big pushes were failing with
#        `Argument list too long` (E2BIG) at the python3 exec call.
#   v1 — original: review piped through REVIEW_OUTPUT env var.

WINGMAN_BRANCH=$(git rev-parse --abbrev-ref HEAD)
WINGMAN_TIMESTAMP=$(date +%Y-%m-%d-%H%M%S)
WINGMAN_REVIEW_DIR=".reviews"
WINGMAN_REVIEW_FILE="${WINGMAN_REVIEW_DIR}/${WINGMAN_TIMESTAMP}-${WINGMAN_BRANCH//\//-}.json"
WINGMAN_BASE="${WINGMAN_BASE:-main}"

# Skip main/develop/master branches
if [[ "$WINGMAN_BRANCH" != "main" && "$WINGMAN_BRANCH" != "master" && "$WINGMAN_BRANCH" != "develop" ]]; then
    mkdir -p "$WINGMAN_REVIEW_DIR"

    _wingman_run() {
        local _start _end _wall _review_file
        _start=$(date +%s)
        _review_file=$(mktemp -t wingman-review.XXXXXX)
        # Clean up the temp file on any exit path from this function.
        trap 'rm -f "$_review_file"' RETURN
        if [ -n "${WINGMAN_MODEL:-}" ]; then
            codex review -c "model=\"$WINGMAN_MODEL\"" --base "$WINGMAN_BASE" >"$_review_file" 2>&1 || true
        else
            codex review --base "$WINGMAN_BASE" >"$_review_file" 2>&1 || true
        fi
        _end=$(date +%s)
        _wall=$((_end - _start))

        # Extract reviewer metadata from the codex banner (first ~10 lines).
        local _tool_version _model _provider _reasoning _session_id
        _tool_version=$(grep -m1 "^OpenAI Codex" "$_review_file" | sed -E "s/^OpenAI Codex ([^ ]+).*/\1/")
        _model=$(grep -m1 "^model:" "$_review_file" | sed "s/^model: *//")
        _provider=$(grep -m1 "^provider:" "$_review_file" | sed "s/^provider: *//")
        _reasoning=$(grep -m1 "^reasoning effort:" "$_review_file" | sed "s/^reasoning effort: *//")
        _session_id=$(grep -m1 "^session id:" "$_review_file" | sed "s/^session id: *//")

        # Pass the *path* to the review (tiny) instead of the review *content*
        # (hundreds of KB), which would overflow ARG_MAX on macOS and fail the
        # python3 exec with E2BIG.
        WINGMAN_REVIEW_INPUT="$_review_file" \
        WINGMAN_TOOL_VERSION="$_tool_version" \
        WINGMAN_MODEL_USED="$_model" \
        WINGMAN_PROVIDER="$_provider" \
        WINGMAN_REASONING="$_reasoning" \
        WINGMAN_SESSION_ID="$_session_id" \
        WINGMAN_WALL_SECONDS="$_wall" \
        WINGMAN_BRANCH="$WINGMAN_BRANCH" \
        WINGMAN_TIMESTAMP="$WINGMAN_TIMESTAMP" \
        WINGMAN_BASE="$WINGMAN_BASE" \
        WINGMAN_REVIEW_FILE="$WINGMAN_REVIEW_FILE" \
        python3 - <<'WINGMAN_PYEOF'
import json, os
with open(os.environ["WINGMAN_REVIEW_INPUT"], "r", encoding="utf-8", errors="replace") as _f:
    raw = _f.read()
status = "clean" if not raw.strip() else "needs_categorization"
def _v(name):
    val = os.environ.get(name, "")
    return val if val else None
data = {
    "wingman_schema_version": "2",
    "branch": os.environ["WINGMAN_BRANCH"],
    "timestamp": os.environ["WINGMAN_TIMESTAMP"],
    "base": os.environ["WINGMAN_BASE"],
    "reviewer": {
        "tool": "codex",
        "tool_version": _v("WINGMAN_TOOL_VERSION"),
        "model": _v("WINGMAN_MODEL_USED"),
        "provider": _v("WINGMAN_PROVIDER"),
        "reasoning_effort": _v("WINGMAN_REASONING"),
        "session_id": _v("WINGMAN_SESSION_ID"),
        "wall_seconds": int(os.environ.get("WINGMAN_WALL_SECONDS", "0")),
    },
    "raw_review": raw,
    "findings": [],
    "resolutions": [],
    "status": status,
}
with open(os.environ["WINGMAN_REVIEW_FILE"], "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
WINGMAN_PYEOF
    }

    _wingman_run &
fi
# --- End Wingman ---
